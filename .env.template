# Copy this file to .env and replace with your actual keys

# --- API Key Authentication ---
# When set, all /api/v1/* endpoints require X-API-Key header.
# Leave empty to disable auth (suitable for local development).
# API_KEY="your-secret-api-key"

# --- LLM Provider (generic, works with any OpenAI-compatible API) ---
LLM_MODEL="deepseek-chat"
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://api.deepseek.com/v1"
# LLM_TIMEOUT=180
# LLM_MAX_RETRIES=1

# Legacy alias — if LLM_API_KEY is unset, these are used as fallback
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
# Comma-separated origins, e.g. local frontend dev servers
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"
# Optional: override default local storage paths
SQLALCHEMY_DATABASE_URI="sqlite+aiosqlite:///./data/sqlite/argos.db"
CHROMA_DB_DIR="./data/chroma"

# RAG Feature (set to false to disable RAG Q&A and skip model downloads ~2GB)
# RAG_ENABLED=true

# GitHub scraper (optional — increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=""

# Hacker News scraper defaults
HN_FETCH_TOP_STORIES=30
HN_MIN_SCORE=100

# Reddit scraper defaults
REDDIT_FETCH_COMMENTS=5

# Email Push Settings
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="you@example.com"
SMTP_PASSWORD="your_password"
SMTP_FROM="Argos <you@example.com>"
EMAIL_SUBSCRIBERS=["me@example.com", "team@example.com"]
DAILY_PUSH_TIME="08:00"

# Notification Channels — comma-separated: email,webhook,bark,telegram
NOTIFY_CHANNELS="email"

# Webhook (generic HTTP POST, works with Discord/Slack/custom bots)
# WEBHOOK_URL="https://your-webhook-endpoint.com/hook"
# WEBHOOK_SECRET=""

# Bark (iOS push notifications)
# BARK_URL="https://api.day.app/YOUR_DEVICE_KEY"
# BARK_GROUP="Argos"

# Telegram Bot
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# TELEGRAM_CHAT_ID="your_chat_id"
